{
  // Vim extension configuration
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.leader": "<space>",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    "<C-c>": false,
    "<C-v>": false,
    "<C-x>": false,
    "<C-z>": false,
    "<C-y>": false,
    "<C-d>": false,
    "<C-u>": false,
    "<C-o>": false,
    "<C-i>": false,
    "<C-w>": false,
    "<C-n>": false,
    "<C-p>": false
  },
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"]
    },
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["leader", "w"],
      "commands": ["workbench.action.files.save"]
    },
    {
      "before": ["leader", "q"],
      "commands": ["workbench.action.closeActiveEditor"]
    },
    {
      "before": ["leader", "Q"],
      "commands": ["workbench.action.closeAllEditors"]
    },
    {
      "before": ["leader", "h"],
      "commands": ["workbench.action.previousEditor"]
    },
    {
      "before": ["leader", "l"],
      "commands": ["workbench.action.nextEditor"]
    },
    {
      "before": ["leader", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["leader", "f", "g"],
      "commands": ["workbench.action.findInFiles"]
    },
    {
      "before": ["leader", "f", "b"],
      "commands": ["workbench.action.showAllEditorsByMostRecentlyUsed"]
    },
    {
      "before": ["leader", "e"],
      "commands": ["workbench.view.explorer"]
    },
    {
      "before": ["leader", "g", "e"],
      "commands": ["workbench.view.scm"]
    },
    {
      "before": ["leader", "g", "g"],
      "commands": ["lazygit-vscode.toggle"]
    },
    {
      "before": ["leader", "o", "t"],
      "commands": ["workbench.action.terminal.toggleTerminal"]
    },
    {
      "before": ["leader", "n"],
      "commands": ["editor.action.marker.next"]
    },
    {
      "before": ["leader", "m"],
      "commands": ["editor.action.marker.prev"]
    },
    {
      "before": ["leader", "a"],
      "commands": ["editor.action.quickFix"]
    },
    {
      "before": ["leader", "c", "f"],
      "commands": ["editor.action.formatDocument"]
    },
    {
      "before": ["leader", "s", "i"],
      "commands": ["workbench.action.output.show.lsp"]
    },
    {
      "before": ["g", "d"],
      "commands": ["editor.action.revealDefinition"]
    },
    {
      "before": ["g", "r"],
      "commands": ["editor.action.goToReferences"]
    },
    {
      "before": ["K"],
      "commands": ["editor.action.showHover"]
    },
    {
      "before": ["leader", "t"],
      "commands": ["editor.action.showHover"]
    }
  ],

  // Auto-hide sidebar when focusing editor
  "workbench.tree.indent": 20,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": true,
  "workbench.editor.tabSizing": "shrink",

  // Explorer settings
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.autoReveal": true,

  // Terminal settings
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.enablePersistentSessions": false,

  // Editor settings
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.fontLigatures": true,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.defaultFormatter": null,
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "boundary",
  "editor.cursorBlinking": "solid",
  "editor.smoothScrolling": true,
  "editor.mouseWheelScrollSensitivity": 1,
  "editor.fastScrollSensitivity": 5,

  // Git settings
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",

  // Disable default conflicting keybindings
  "workbench.enableExperiments": false,
  "extensions.autoUpdate": false
}
